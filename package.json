{
  "name": "private-browser",
  "version": "1.1.1",
  "private": true,
  "description": "Leef is a fast, private, and modern Electron-based web browser built for everyday use.",
  "homepage": "https://leefbrowser.site",
  "bugs": {
    "url": "https://github.com/git-QTech/leef/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/git-QTech/leef.git"
  },
  "license": "ISC",
  "author": "QTech",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.14.1",
    "app-builder-bin": "^5.0.0-alpha.12",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.quinn.leefbrowser",
    "productName": "Leef Browser",
    "publish": [
      {
        "provider": "github",
        "owner": "git-QTech",
        "repo": "leef"
      }
    ],
    "compression": "maximum",
    "files": [
      "preload.cjs",
      "main.js",
      "renderer.js",
      "index.html",
      "style.css",
      "offline.html",
      "recovery.html",
      "images/**/*",
      "!dist/**/*",
      "!src/**/*",
      "!public/**/*",
      "!Local Storage/**/*",
      "!Partitions/**/*",
      "!Network/**/*",
      "!Cookies*",
      "!*.log",
      "!.git/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "images/icon.png",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "mac": {
      "icon": "images/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "images/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "dmg": {
      "title": "Leef Browser Setup",
      "background": "images/dmg-background.png",
      "iconSize": 120,
      "window": {
        "width": 674,
        "height": 371
      },
      "contents": [
        {
          "x": 154,
          "y": 186,
          "type": "file"
        },
        {
          "x": 515,
          "y": 186,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "include": "build/installer.nsh",
      "allowToChangeInstallationDirectory": true,
      "artifactName": "leef-browser-setup-${version}.${ext}"
    },
    "asar": true
  },
  "overrides": {
    "ip-address": "10.1.1"
  }
}