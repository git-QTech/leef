{
  "name": "private-browser",
  "version": "0.1.3",
  "description": "Leef is a fast, private, and modern Electron-based web browser built for everyday use.",
  "author": "QTech",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.quinn.leefbrowser",
    "productName": "Leef Browser",
    "compression": "maximum",
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "style.css",
      "images/**/*",
      "!**/.vscode/*",
      "!src/*",
      "!node_modules/*",
      "!dist/*",
      "!*.md",
      "!*.map"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "asar": true
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.4"
  }
}
